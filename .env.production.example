# Твой домен или IP сервера (БЕЗ слеша в конце)
SITE_URL=http://your-server-ip-or-domain.com

# Пароль для PostgreSQL (придумай любой)
DB_PASSWORD=change_me_strong_password

# JWT секрет (любая длинная случайная строка)
JWT_SECRET=change_me_very_long_random_string_here_minimum_32_chars

# Google OAuth Client ID
GOOGLE_CLIENT_ID=1085102604446-74mk9ktn94t232036rlpnennqqq0chsp.apps.googleusercontent.com

# Учётные данные главного администратора
ADMIN_EMAIL=admin@ketemedu.com
ADMIN_PASSWORD=Admin123!
